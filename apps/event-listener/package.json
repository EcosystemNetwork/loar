{
  "name": "event-listener",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "LOAR on-chain event listener — writes to Firestore (replaces Ponder + Neon).",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "esbuild src/index.ts --bundle --platform=node --format=esm --outfile=dist/index.js --packages=external",
    "check-types": "tsc --noEmit",
    "lint": "eslint ."
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@loar/abis": "workspace:*",
    "dotenv": "^17.2.1",
    "firebase-admin": "^13.0.0",
    "hono": "^4.8.2",
    "@hono/node-server": "^1.19.11",
    "pino": "^9.5.0",
    "viem": "~2.47.6",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@eslint/js": "^9.18.0",
    "@types/node": "^20.9.0",
    "esbuild": "^0.25.0",
    "eslint": "^9.18.0",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3",
    "typescript-eslint": "^8.21.0"
  }
}

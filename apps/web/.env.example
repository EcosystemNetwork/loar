# ============================================
# LOAR Web — Environment Variables (VITE_*)
# ============================================
# All VITE_ variables are embedded into the JavaScript bundle at build time.
# ⚠  NEVER put secrets here — anyone can read these from the browser.
#
# Local dev: copy root .env.example → root .env (all services share it).
# Production (Vercel): add these in the Vercel project dashboard under
#   Settings → Environment Variables.

# ── Required ─────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
VITE_SERVER_URL=https://api.loar.fun

# ── Optional endpoints ────────────────────────────────────────────────────────
# Ponder indexer GraphQL endpoint
VITE_PONDER_URL=https://idx.loar.fun

# ── Blockchain (public contract addresses) ────────────────────────────────────
VITE_LOAR_TOKEN_ADDRESS=0x...
VITE_TREASURY_ADDRESS=0x...

# ── Admin toolbar ─────────────────────────────────────────────────────────────
# Comma-separated wallet addresses shown the admin toolbar (empty = disabled)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# ── Coinbase Developer Platform ───────────────────────────────────────────────
# Project ID only — do NOT add CDP_API_KEY or CDP_API_SECRET here (server-only)
# VITE_CDP_PROJECT_ID=

# ── Firebase web client config (public — safe to expose) ─────────────────────
# These are the web SDK credentials, NOT the admin service account.
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

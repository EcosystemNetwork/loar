# ============================================
# LOAR Web — Environment Variables (VITE_*)
# ============================================
# All VITE_ variables are embedded into the JavaScript bundle at build time.
# ⚠  NEVER put secrets here — anyone can read these from the browser.
#
# Local dev: copy root .env.example → root .env (all services share it).
# Production (Vercel): add these in the Vercel project dashboard under
#   Settings → Environment Variables.

# ── Required ─────────────────────────────────────────────────────────────────
# Backend API base URL (no trailing slash)
VITE_SERVER_URL=https://api.loar.fun

# ── Optional endpoints ────────────────────────────────────────────────────────
# Ponder indexer GraphQL endpoint
VITE_PONDER_URL=https://idx.loar.fun
# Optional fallback indexer for failover
# VITE_PONDER_URL_FALLBACK=https://idx-backup.loar.fun
# Feature flag — proxy indexer reads through tRPC instead of fetching GraphQL directly
# VITE_USE_TRPC_INDEXER=false

# ── Chain environment ─────────────────────────────────────────────────────────
# "testnet" = Sepolia + Base Sepolia (default), shows the testnet banner
# "mainnet" = Base mainnet only
# VITE_CHAIN_ENV=testnet
# Default chain ID for SIWE / pricing calls when wallet hasn't reported one
# VITE_CHAIN_ID=84532

# ── Blockchain (public contract addresses) ────────────────────────────────────
# Per-chain contract addresses (including $LOAR token) are hardcoded in
# apps/web/src/configs/addresses.ts. Only the chain-independent treasury EOA is env-driven.
VITE_TREASURY_ADDRESS=0x...

# ── IPFS / Pinata gateway (public) ────────────────────────────────────────────
# Public Pinata gateway URL used to resolve ipfs:// links. The gateway auth
# token lives on the server only; for dedicated `.mypinata.cloud` gateways
# the client calls /api/ipfs/resolve to get a signed URL.
# VITE_PINATA_GATEWAY_URL=https://gateway.pinata.cloud
# Prefer the public gateway over /api/ipfs/resolve (faster but loses auth)
# VITE_PINATA_PREFER_PUBLIC=false

# ── Stripe (card payments — public key only) ─────────────────────────────────
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ── Admin toolbar ─────────────────────────────────────────────────────────────
# Comma-separated wallet addresses shown the admin toolbar (empty = disabled)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# ── WalletConnect ────────────────────────────────────────────────────────────
# Project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# ── Google OAuth (Sign-In with Google button) ─────────────────────────────────
# Same client ID as the server's GOOGLE_OAUTH_CLIENT_ID (public, safe to expose).
# Leave empty to hide the Google sign-in button.
# VITE_GOOGLE_OAUTH_CLIENT_ID=12345-abc.apps.googleusercontent.com

# ── Firebase web client config (public — safe to expose) ─────────────────────
# These are the web SDK credentials, NOT the admin service account.
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ── Monitoring (Sentry — DSN is public by design) ─────────────────────────────
# Browser DSN from sentry.io; release tag pins source maps to a build.
# VITE_SENTRY_DSN=https://abc@oXXX.ingest.sentry.io/XXX
# VITE_RELEASE=loar-web@0.1.0-beta

# ── Product analytics (PostHog — public project key) ──────────────────────────
# Lazy-loaded only when VITE_POSTHOG_KEY is set.
# VITE_POSTHOG_KEY=phc_...
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# ── Generation defaults ───────────────────────────────────────────────────────
# Override the default image model shown in the studio. Falls back to a
# server-chosen default if unset.
# VITE_DEFAULT_IMAGE_MODEL=imagen-4

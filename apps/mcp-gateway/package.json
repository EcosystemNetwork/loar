{
  "name": "@loar/mcp-gateway",
  "version": "0.1.0",
  "description": "OAuth 2.1 gateway for hosted MCP SSE at mcp.loar.fun — bridges browser agents to per-user MCP sessions",
  "private": true,
  "type": "module",
  "main": "dist/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",

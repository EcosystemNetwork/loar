{
  "name": "@loar/mcp-server",
  "version": "0.2.0",
  "description": "LOAR platform MCP server — AI agent tools for tokenized AI story universes (loar.fun)",
  "private": false,
  "type": "module",
  "bin": {
    "loar-mcp-server": "dist/src/index.js"
  },
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "files": [
    "dist/src/",
    "!dist/**/*.tsbuildinfo",
    "README.md",
    "LICENSE"
  ],
  "scripts": {

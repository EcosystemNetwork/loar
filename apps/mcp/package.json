    "build": "tsc -b",
    "start": "node dist/src/index.js",
    "check-types": "tsc -b",
    "prepublishOnly": "pnpm build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^0.5.0",
    "zod": "^4.0.2"
  },
  "devDependencies": {
    "@types/node": "^20.19.37",
    "tsx": "^4.21.0",
    "typescript": "^5.8.3"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/loar-fun/loar.git",
    "directory": "apps/mcp"
  },
  "homepage": "https://loar.fun/docs/agent-integration",
  "bugs": {
    "url": "https://github.com/loar-fun/loar/issues"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "openclaw",
    "hermes",
    "loar",
    "ai-video",

# ============================================
# LOAR Server — Environment Variables
# ============================================
# This file contains ONLY the secrets the server needs.
# Never expose these values to the browser.
#
# Local dev: copy root .env.example → root .env (all services share it).
# Production: inject only these vars into the server container/process.

# ── Core ─────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000
# Required in production — your public domain (no trailing slash)
CORS_ORIGIN=https://loar.fun
# Required when running behind a reverse proxy (Railway/Fly/Vercel) so the
# rate limiter sees the real client IP from X-Forwarded-For instead of the
# proxy IP. Set to "true" or the trust-proxy spec your platform documents.
TRUST_PROXY=true

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
SIWE_JWT_SECRET=

# ── BYOK (Bring-Your-Own-Key) encryption ─────────────────────────────────────
# AES-256-GCM master key for encrypting user-supplied external API keys at
# rest in Firestore (e.g. ByteDance ModelArk). Without this, /api/userSecrets
# routes throw — and BYO-key features are disabled.
# Generate: openssl rand -hex 32
USER_SECRETS_MASTER_KEY=

# ── Firebase Admin (Firestore) ───────────────────────────────────────────────
# Option A — inline JSON string (preferred for container environments):
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"..."}'
# Option B — path to a mounted credentials file:
# FIREBASE_SERVICE_ACCOUNT_PATH=/run/secrets/firebase-sa.json

FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ── Admin ─────────────────────────────────────────────────────────────────────
# Wallet address that can call privileged admin routes
ADMIN_WALLET=0x...
# Comma-separated list — all are granted admin tRPC access (empty = none)
# ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# ── Blockchain ────────────────────────────────────────────────────────────────
# 64 hex characters, no 0x prefix — required for on-chain write operations
PRIVATE_KEY=

# RPC endpoints for on-chain verification (credits, treasury, safe-admin)
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
RPC_URL_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# Contract addresses — required for payment verification
TREASURY_ADDRESS=0x...
LOAR_TOKEN_ADDRESS=0x...

# ── Stripe (card payments) ───────────────────────────────────────────────────
# Card payments are disabled if STRIPE_SECRET_KEY is not set.
# Get keys at: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── Circle Developer Controlled Wallets (server-signed tx, social auth) ──────
# Each user gets a Circle-managed EOA; the server signs via Circle's KMS so
# users only need email/social credentials. Without all three, /auth/circle/*
# and /api/tx/write return 503.
CIRCLE_API_KEY=
CIRCLE_ENTITY_SECRET=
CIRCLE_WALLET_SET_ID=
# Optional extra contracts the signing oracle should accept,
# comma-separated as "chainId:0xaddr":
# CONTRACT_ALLOWLIST_EXTRA=84532:0xabc...,11155111:0xdef...

# ── Google OAuth (Circle social login idToken verification) ──────────────────
# Used by /auth/circle/social to verify Google idTokens before trusting email.
# Same client ID is exposed publicly via VITE_GOOGLE_OAUTH_CLIENT_ID.
GOOGLE_OAUTH_CLIENT_ID=

# ── Platform config ───────────────────────────────────────────────────────────
# Credits awarded on universe mint (default: 5000)
# UNIVERSE_MINT_CREDITS=5000

# ── AI Services ──────────────────────────────────────────────────────────────
# Server starts without these; individual features will fail if the key is absent.
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
MESHY_API_KEY=
ELEVENLABS_API_KEY=

# ── Unstoppable Domains (reverse-resolve wallet → domain in UI) ──────────────
# Get key at: https://unstoppabledomains.com/partner/dashboard
# When unset the /api/ud/reverse endpoint returns null (UI falls back to truncated address).
UNSTOPPABLE_DOMAINS_API_KEY=

# ── Storage — Pinata (hot/public) ────────────────────────────────────────────
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud
# Server-only gateway access token (do NOT prefix with VITE_)
# PINATA_GATEWAY_TOKEN=

# ── Storage — Lighthouse (permanent/Filecoin + encrypted) ────────────────────
# Get API key at: https://lighthouse.storage
LIGHTHOUSE_API_KEY=

# Provider priority (comma-separated — first available wins for primary upload)
STORAGE_PROVIDER_PRIORITY=pinata,lighthouse,firebase

# ── Redis (queue + rate limiting; optional for dev, required for prod) ───────
# Without REDIS_URL the in-memory rate limiter resets on every deploy and the
# generation worker / VLM worker / webhook worker do not start.
# REDIS_URL=redis://default:password@host:6379
# WORKER_CONCURRENCY=5
# VLM_WORKER_DISABLED=true

# ── DMCA putback job (single-writer; set on EXACTLY one replica in prod) ─────
# Hourly cron that auto-restores hidden content after the §512(g) hold.
# DMCA_PUTBACK_ENABLED=true

# ── MCP webhook worker (signed POST delivery for agent integrations) ─────────
# Worker only starts when this is set. Generate: openssl rand -hex 32
# WEBHOOK_SIGNING_SECRET=

# ── Firestore disaster-recovery backups ──────────────────────────────────────
# GCS bucket created via: gsutil mb gs://your-bucket
# IAM: Cloud Datastore Import Export Admin + Storage Admin
# FIRESTORE_BACKUP_BUCKET=
# FIRESTORE_BACKUP_PREFIX=backups

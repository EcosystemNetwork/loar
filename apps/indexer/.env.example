# ============================================
# LOAR Indexer — Environment Variables
# ============================================
# The indexer needs an RPC endpoint for the target chain.
#
# Local dev: copy root .env.example → root .env (all services share it).
# Production: inject only these vars into the indexer container/process.

# ── Required ─────────────────────────────────────────────────────────────────
# RPC endpoint (use a paid tier in production to avoid rate limits)
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ── Chain selection (optional, defaults to sepolia) ──────────────────────────
# Set to "base-sepolia" to index Base Sepolia instead
# PONDER_CHAIN=sepolia

# ============================================
# LOAR Indexer — Environment Variables
# ============================================
# The indexer only needs an RPC endpoint for Sepolia.
#
# Local dev: copy root .env.example → root .env (all services share it).
# Production: inject only this var into the indexer container/process.

# ── Required ─────────────────────────────────────────────────────────────────
# Sepolia RPC endpoint (use a paid tier in production to avoid rate limits)
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

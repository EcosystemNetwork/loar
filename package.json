{
  "name": "loar-fullstack",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "lint": "turbo lint",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "prepare": "husky || true",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "sc:test": "turbo run sc:test",
    "sc:test:cov": "turbo run sc:test:cov",
    "sc:test:integration": "turbo run sc:test:integration",
    "deploy:sepolia": "bash scripts/deploy-sepolia.sh",
    "deploy:base-sepolia": "bash scripts/deploy-base-sepolia.sh",
    "sync:addresses": "tsx scripts/rebuild-deployments.ts --apply",
    "check:addresses": "tsx scripts/check-addresses.ts",
    "smoke": "tsx scripts/smoke/index.ts",
    "smoke:chain": "SMOKE_LAYER=chain tsx scripts/smoke/index.ts",
    "smoke:server": "SMOKE_LAYER=server tsx scripts/smoke/index.ts",
    "smoke:launchpad": "SMOKE_LAYER=launchpad tsx scripts/smoke/index.ts",
    "smoke:ci": "tsx scripts/smoke/index.ts --json",
    "qa:visual": "tsx scripts/qa-visual/index.ts",
    "qa:visual:shots": "tsx scripts/qa-visual/index.ts --no-review"
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "@fal-ai/serverless-client": "^0.15.0",
    "@metaplex-foundation/umi-web3js-adapters": "^0.9.2",
    "@solana/spl-token-metadata": "^0.1.6",
    "@wagmi/cli": "^0.0.0-canary-20251023193249",
    "dotenv": "^16.6.1",
    "esbuild": "^0.28.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.4.3",
    "playwright": "^1.59.1",
    "prettier": "^3.5.3",
    "tsx": "^4.19.2",
    "turbo": "^2.5.4"
  },
  "packageManager": "pnpm@9.15.0",
  "pnpm": {
    "overrides": {
      "protobufjs@<7.5.5": ">=7.5.5",
      "hono@<4.12.14": ">=4.12.14",
      "@hono/node-server@<1.19.13": ">=1.19.13",
      "@modelcontextprotocol/sdk@<1.25.2": ">=1.25.2",
      "@xmldom/xmldom@<0.8.12": ">=0.8.12",
      "axios@<1.15.0": ">=1.15.0",
      "follow-redirects@<=1.15.11": ">=1.15.12",
      "defu@<6.1.5": ">=6.1.5",
      "drizzle-orm@<0.45.2": ">=0.45.2",
      "kysely@<0.28.12": ">=0.28.12",
      "tar@<7.5.10": ">=7.5.10",
      "vite@<6.4.2": "~6.4.2",
      "ponder>vite": "5.4.21",
      "ponder>vite-node": "1.0.2"
    },
    "auditConfig": {
      "ignoreGhsas": [
        "GHSA-r5fr-rjxr-66jc"
      ]
    }
  }
}

# ============================================
# LOAR — Environment Variables
# ============================================
# Copy to .env and fill in your values:  cp .env.example .env
# All apps (server, web, indexer) read from this single root file.

# ============================================
# REQUIRED — Server won't start without these
# ============================================

# Secret for signing SIWE session JWTs (generate: openssl rand -hex 32)
SIWE_JWT_SECRET=

# Firebase Firestore — provide JSON string OR file path (one is required in production)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ============================================
# Web (VITE_ prefix = exposed to browser)
# ============================================
VITE_SERVER_URL=http://localhost:3000
VITE_PONDER_URL=http://localhost:42069

# Admin toolbar — comma-separated wallet addresses (empty = all authenticated users)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# ============================================
# Indexer (Ponder) — REQUIRED for indexer
# ============================================
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================================
# AI Services (optional — server starts without them)
# ============================================
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ============================================
# Blockchain / Web3
# ============================================
# Wallet private key (for Synapse/Filecoin uploads, no 0x prefix)
PRIVATE_KEY=

# ============================================
# Storage — Firebase Storage
# ============================================
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ============================================
# Decentralized Storage (optional)
# ============================================
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud
STORAGE_PROVIDER_PRIORITY=walrus,ipfs,synapse,firebase

# ============================================
# Coinbase Developer Platform (optional)
# ============================================
# VITE_CDP_PROJECT_ID=
# VITE_CDP_API_KEY=
# VITE_CDP_API_SECRET=

# ============================================
# Contracts (Foundry) — see also apps/contracts/.env.example
# ============================================
# RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_1=YOUR_ETHERSCAN_API_KEY

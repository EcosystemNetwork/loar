# ============================================
# LOAR — Root Environment Variables
# ============================================
# LOCAL DEVELOPMENT ONLY — convenience bundle for running all services
# from one place with `pnpm dev`.
#
# Production: each service reads only its own secrets.
#   Server secrets  → apps/server/.env.example
#   Web public vars → apps/web/.env.example
#   Indexer         → apps/indexer/.env.example
#
# Copy this file:  cp .env.example .env

# ============================================
# SERVER — secrets (never expose to browser)
# ============================================

# Secret for signing SIWE session JWTs (generate: openssl rand -hex 32)
SIWE_JWT_SECRET=

# During JWT-secret rotation, set this to the PREVIOUS SIWE_JWT_SECRET for a
# 24h grace window. verifySessionToken() tries the current secret first, then
# falls back to the previous one so in-flight sessions don't all 401 at once.
# Rotation procedure (see apps/server/src/lib/siwe.ts):
#   1. SIWE_JWT_SECRET_PREVIOUS = <current SIWE_JWT_SECRET>
#   2. SIWE_JWT_SECRET          = <new value from `openssl rand -hex 32`>
#   3. Deploy
#   4. After 24h (JWT TTL), remove SIWE_JWT_SECRET_PREVIOUS
# SIWE_JWT_SECRET_PREVIOUS=

# AES-256-GCM master key for encrypting user-supplied external API keys at
# rest (BYOK — e.g. user's own ByteDance ModelArk key). Without this set,
# /api/userSecrets endpoints throw and BYO-key UI is disabled.
# Generate: openssl rand -hex 32
USER_SECRETS_MASTER_KEY=

# Firebase Admin — Firestore access (one is required in production).
# Pick ONE of these two forms:
#   (A) FIREBASE_SERVICE_ACCOUNT — full JSON inline (convenient for CI / env-only platforms)
#   (B) FIREBASE_SERVICE_ACCOUNT_PATH — path to a .json key file, relative to repo root
# Without valid creds the server runs in degraded mode (in-memory nonces, no Firestore writes),
# so tRPC mutations like universes.create will fail. Scripts that hit /trpc/universes.create
# also need the server to be started with one of these set.
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=firebase-service-account.json

FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

NODE_ENV=development
PORT=3000
# Single URL or comma-separated list for multiple origins (staging, mobile webview, etc.)
CORS_ORIGIN=http://localhost:5173
# Set to 'true' when behind a reverse proxy (nginx, Railway, etc.)
# Enables rate-limit IP extraction from x-forwarded-for / x-real-ip headers.
# Without this, only the socket remote address is used (preventing IP spoofing).
TRUST_PROXY=false
# Set to 'true' to show stack traces in error responses (never enable in production)
# LOAR_DEBUG_ERRORS=false

# Comma-separated allowed domains for SIWE (optional, defaults to CORS_ORIGIN)
# SIWE_ALLOWED_DOMAINS=loar.fun,staging.loar.fun
# Comma-separated chain IDs accepted in SIWE messages. Defaults to
# 8453,84532,11155111,31337 (Base, Base Sepolia, Sepolia, Anvil).
# SIWE_ALLOWED_CHAIN_IDS=8453,84532,11155111

# Admin
ADMIN_WALLET=
# ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# Blockchain — wallet private key for on-chain writes (64 hex chars, no 0x prefix)
# Development only — use KMS_KEY_ID in production (see below)
PRIVATE_KEY=

# AWS KMS — production signing (private key never leaves HSM)
# Create key: aws kms create-key --key-spec ECC_SECG_P256K1 --key-usage SIGN_VERIFY
# IAM policy: kms:Sign, kms:GetPublicKey on the key ARN
# KMS_KEY_ID=arn:aws:kms:us-east-1:123456789:key/mrk-xxxx
# KMS_REGION=us-east-1

# On-chain payment verification (used by server to validate $LOAR credit purchases)
# RPC_URL falls back to PONDER_RPC_URL_2 if unset — set separately for isolation
RPC_URL=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Server-side token + treasury addresses (mirrors VITE_ vars but kept server-only)
LOAR_TOKEN_ADDRESS=0x...
TREASURY_ADDRESS=
LOAR_FAUCET_ADDRESS=

# Contract addresses — deployed via: forge script script/DeployAll.s.sol
UNIVERSE_MANAGER=
PAYMENT_ROUTER_ADDRESS=
RIGHTS_REGISTRY_ADDRESS=
SPLIT_ROUTER_ADDRESS=
LAUNCHPAD_STAKING_ADDRESS=
CREDIT_MANAGER_ADDRESS=
SUBSCRIPTION_MANAGER_ADDRESS=
LICENSING_REGISTRY_ADDRESS=
AD_PLACEMENT_ADDRESS=
CANON_MARKETPLACE_ADDRESS=
COLLAB_MANAGER_ADDRESS=
ANALYTICS_REGISTRY_ADDRESS=
STORY_BOUNTIES_ADDRESS=
ESCROW_ADDRESS=
REVENUE_MODULE_FACTORY=
PLATFORM_TREASURY_ADDRESS=

# Platform
# UNIVERSE_MINT_CREDITS=5000

# AI Services (optional — server starts without them)
FAL_KEY=
BYTEDANCE_API_KEY=              # ByteDance ModelArk — Seedance 2.0, Seedream 5.0, Seed Speech. Comma-separated for backup keys (rotates on auth/rate-limit failures)
GOOGLE_API_KEY=
OPENAI_API_KEY=
MESHY_API_KEY=
ELEVENLABS_API_KEY=

# Unstoppable Domains — reverse-resolve wallet → .crypto/.eth domains in UI
# Get a key at https://unstoppabledomains.com/partner/dashboard
# When unset the /api/ud/reverse endpoint returns null (UI shows truncated address).
UNSTOPPABLE_DOMAINS_API_KEY=

# Storage — Pinata (hot path, public delivery)
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud
# Dedicated Pinata gateways on *.mypinata.cloud require a gateway access token.
# Get one at https://app.pinata.cloud/gateway → your gateway → Access Controls.
# Used by both server (IPFSAdapter) and the client IPFS URL helper.
# PINATA_GATEWAY_TOKEN=

# Storage — Lighthouse (permanent Filecoin + encrypted assets)
LIGHTHOUSE_API_KEY=

STORAGE_PROVIDER_PRIORITY=pinata,lighthouse,firebase

# Content Provenance — C2PA signing for AI-generated content (optional)
# Generate self-signed cert for testnet:
#   openssl req -x509 -newkey ec -pkeyopt ec_paramgen_curve:P-256 \
#     -keyout c2pa-key.pem -out c2pa-cert.pem -days 365 -nodes -subj "/CN=LOAR Platform"
# Values should be PEM-encoded (paste the full -----BEGIN/END----- blocks)
C2PA_PRIVATE_KEY=
C2PA_CERTIFICATE=

# Email — Resend transactional emails (optional, email disabled if unset)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# FROM_EMAIL=noreply@loar.fun
# Public-facing base URL embedded in DMCA notices, counter-notice deep
# links, and other transactional emails. Defaults to https://loar.fun.
# APP_BASE_URL=https://loar.fun

# Queue — BullMQ generation queue admission control
# MAX_CONCURRENT_GENERATIONS=50
# MAX_QUEUED_GENERATIONS=200
# WORKER_CONCURRENCY=5

# Horizontal scaling (production docker-compose) — passed to `docker compose up
# --scale server=N --scale worker=N`. Total concurrent AI jobs =
# WORKER_REPLICAS × WORKER_CONCURRENCY. See docs/scale-readiness-10k.md for
# sizing guidance.
# SERVER_REPLICAS=4
# WORKER_REPLICAS=2

# MCP Server — LOAR platform access for AI agents
# LOAR_SERVER_URL=http://localhost:3000
# LOAR_API_KEY=loar_xxxxxxxxxxxx
# Transport — "stdio" (default, for direct agent wiring) or "http"
# LOAR_MCP_TRANSPORT=stdio
# HTTP transport bind (only used when LOAR_MCP_TRANSPORT=http)
# LOAR_MCP_HOST=0.0.0.0
# LOAR_MCP_PORT=4000

# Redis — BullMQ generation queue + distributed rate limiting.
# REQUIRED for async AI generation. Without it, mutations run inline and
# block the HTTP request for 60s+ (mobile/web will hit gateway timeouts).
# Local dev: `redis-server --daemonize yes` or `docker compose up -d redis`.
REDIS_URL=redis://localhost:6379
# REDIS_PASSWORD=changeme

# ── Webhook delivery (MCP integration §2) ─────────────────────────────
# HMAC-SHA256 secret used to sign outbound webhook bodies. Generate with:
#   openssl rand -hex 32
# Receivers verify via header `X-Loar-Signature: sha256=<hex>` over
# `${X-Loar-Timestamp}.${body}`. Leave unset to disable webhook delivery
# entirely — `enqueueWebhook()` will silently skip (fail-open for dev).
WEBHOOK_SIGNING_SECRET=
# WEBHOOK_WORKER_CONCURRENCY=10

# Stripe — card payments (server-side secrets)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# ── ERC-4337 Paymaster / gas sponsorship (apps/server/src/routes/paymaster.ts) ──
# Server-side sponsorship for sponsored meta-transactions (mint, vote, universe
# creation). Provider resolved in order: thirdweb → Pimlico → Biconomy. Pick ONE.
# When none are set, /api/paymaster returns 501 and sponsorship is disabled.
#
# thirdweb (uses VITE_THIRDWEB_CLIENT_ID as the client ID)
# THIRDWEB_SECRET_KEY=sk_live_xxxxxxxxxxxx
# Pimlico v2 RPC
# PIMLICO_API_KEY=
# Biconomy v2 RPC
# BICONOMY_API_KEY=
# PAYMASTER_DAILY_LIMIT=50                       # per-wallet sponsored ops per day
# PAYMASTER_DEFAULT_CHAIN_ID=84532               # falls back when request omits chainId

# ── CSAM / hash-matching providers (apps/server/src/services/fingerprint) ───
# Run before every image publish. At least ONE provider must be configured
# for production — leaving both unset lets hashed CSAM pass the pipeline.
# Microsoft PhotoDNA: https://www.microsoft.com/photodna
# PHOTODNA_ENDPOINT=https://api.microsoftmoderator.com/photodna/v1.0
# PHOTODNA_SUBSCRIPTION_KEY=
# Hive AI moderation: https://thehive.ai
# HIVE_API_KEY=

# Monitoring — Sentry (optional, error reporting disabled if unset)
SENTRY_DSN=

# Structured logging level — one of: trace | debug | info | warn | error | fatal
# Defaults to `debug` in development and `info` in production.
# LOG_LEVEL=info

# Prometheus /metrics endpoint — bearer token for scraper auth. When set,
# scrapers must send `Authorization: Bearer ${METRICS_AUTH_TOKEN}`. Leave empty
# when the server is on a private network or behind a reverse-proxy allowlist.
# METRICS_AUTH_TOKEN=

# Product analytics — PostHog (server side). Use the PROJECT API key here,
# NOT the personal key. When unset, server-side events are a silent no-op.
# See docs/analytics.md for the event catalogue + privacy posture.
# POSTHOG_API_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# POSTHOG_HOST=https://us.i.posthog.com

# Slack incoming webhook — operator-actionable alerts (kill-switch flips,
# abuse flags). No-op when unset. Use a channel scoped to ops, not #general.
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# Cost tracker — admin-only provider cost attribution + gross-margin gauge.
# Target margin = (revenue - cost) / revenue. Flagged below target.
# COST_MARGIN_TARGET=0.30
# Background alert sweep (margin breach + daily platform cap). Opt-in, ONE replica only.
# COST_ALERT_ENABLED=false
# COST_ALERT_INTERVAL_MS=600000                # 10 min
# COST_ALERT_COOLDOWN_MIN=30                   # minutes between repeat alerts for the same rule
# Hard daily platform cost cap. When today's spend reaches this, every paid
# provider call fails fast with CostCapExceededError until the day rolls over
# or an admin raises the cap via admin.cost.controls.update.
# COST_DAILY_PLATFORM_CAP_USD=500
# Controls cache TTL (ms). Admin mutations invalidate immediately.
# COST_CONTROLS_CACHE_MS=30000

# VLM subsystem — Vision-Language Model intelligence
# See docs/prd-vlm-subsystem.md for the full spec.
# Requires GOOGLE_API_KEY. Server starts without these set; workers/features degrade gracefully.
# VLM_WORKER_DISABLED=false                   # set true to skip the in-process VLM worker
# VLM_WORKER_CONCURRENCY=3
# VLM_AUTO_EXTRACT=true                       # auto-enqueue extract after every generation
# VLM_AUTO_HIDE_HIGH_RISK=false               # hide content when risk=high (requires admin review)
# VLM_EMBEDDINGS=false                        # store text-embedding-004 embeddings on sceneIndex
# VLM_EXTRACT_PER_USER_PER_HOUR=10            # rate limit per user for .start
# VLM_USER_MONTHLY_USD=5                      # per-user monthly VLM budget cap
# VLM_CROSS_MODEL=false                       # ensemble Gemini + OpenAI for high-stakes checks
# VLM_MODERATION_ON_GENERATION=false          # run VLM moderation on every finished generation
# CANON_BLOCK_ON_HIGH=false                   # hard-block publish on block-severity conflicts
# Phase 7 — continuous-film autoplay (opt-in, ONE replica only)
# VLM_CONTINUOUS_FILM=false
# VLM_AUTOPLAY_MAX_PER_DAY=10                 # per universe
# VLM_AUTOPLAY_BUDGET_USD=20                  # per universe / day
# VLM_AUTOPLAY_REQUIRE_VOTE=true              # require on-chain vote before advancing canon

# Abuse detector — opt-in, only enable on ONE replica in multi-replica deploys.
# ABUSE_DETECT_ENABLED=false
# ABUSE_DETECT_INTERVAL_MS=1800000          # 30 min
# ABUSE_DETECT_DAILY_THRESHOLD=100          # spends in 24h before flag
# ABUSE_DETECT_SCAN_LIMIT=500               # most-recent userCredits docs to scan
# ABUSE_DETECT_COOLDOWN_MS=21600000         # 6h — skip re-flagging the same wallet

# DMCA § 512(g) auto-putback — REQUIRED in production, ONE replica only.
# Restores taken-down content when a counter-notice has been pending for
# the hold period with no court action filed. If this job is not running
# in prod, you cannot complete the § 512(g) safe-harbor loop and your
# DMCA defence is incomplete. Set ENABLED=true on exactly one replica.
# DMCA_PUTBACK_ENABLED=true
# DMCA_PUTBACK_INTERVAL_MS=3600000          # 1h sweep
# Business days, not calendar. Statute requires the floor to be in
# [10, 14] business days. The job clamps any value outside that range.
# DMCA_PUTBACK_HOLD_BUSINESS_DAYS=12
# DMCA_PUTBACK_BATCH_LIMIT=50               # counter-notices processed per tick

# ============================================
# WEB — browser-safe vars (VITE_ prefix = public)
# ⚠  Everything with VITE_ is visible in the JS bundle — no secrets here.
# ============================================
VITE_SERVER_URL=http://localhost:3000
VITE_PONDER_URL=http://localhost:42069
# Optional — comma-separated fallback Ponder/GraphQL indexer URLs (tried in order
# on query error or 5xx). Useful for staging→prod failover or mirror replicas.
# VITE_PONDER_URL_FALLBACK=https://idx-backup.loar.fun

# Chain environment: "testnet" (Sepolia + Base Sepolia) or "mainnet" (Base)
VITE_CHAIN_ENV=testnet
# Default chain ID (84532 = Base Sepolia, 11155111 = Sepolia)
# VITE_CHAIN_ID=84532

# Per-chain RPC for wagmi/thirdweb reads. Public viem defaults cap
# eth_getLogs ranges and throttle large eth_call responses — point these
# at Alchemy/Infura/etc. Mirror the server-side RPC_<chainId> values.
VITE_RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
VITE_RPC_84532=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# VITE_RPC_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

# Default AI image model (optional, overrides server default)
# VITE_DEFAULT_IMAGE_MODEL=

# Public contract addresses
# Note: $LOAR token + other per-chain addresses live in apps/web/src/configs/addresses.ts
VITE_TREASURY_ADDRESS=
VITE_LOAR_FAUCET_ADDRESS=
VITE_LOAR_TOKEN_ADDRESS=
VITE_UNIVERSE_MANAGER=
VITE_PAYMENT_ROUTER_ADDRESS=
VITE_SPLIT_ROUTER_ADDRESS=
VITE_LAUNCHPAD_STAKING_ADDRESS=
VITE_STORY_BOUNTIES_ADDRESS=

# Client-side Pinata gateway config — mirrors PINATA_GATEWAY_URL /
# PINATA_GATEWAY_TOKEN on the server. The IPFS URL helper uses these
# to build retrieval URLs for images/videos. Leave blank to use the
# default public gateway (lower throughput).
# VITE_PINATA_GATEWAY_URL=https://gateway.pinata.cloud
# VITE_PINATA_GATEWAY_TOKEN=
# Force the public Pinata gateway even when a dedicated gateway + token are
# configured above. Set to 'true' when the dedicated gateway is misconfigured
# (revoked token, access-control mismatch) so thumbnails keep loading.
# VITE_PINATA_PREFER_PUBLIC=false

# Admin toolbar — comma-separated wallet addresses (empty = disabled)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# Thirdweb — client ID (get from thirdweb.com/dashboard). Safe to expose in the bundle.
VITE_THIRDWEB_CLIENT_ID=
# Thirdweb — secret key (server-only). Used for paymaster / gas sponsorship via the
# server-side proxy (apps/server). NEVER prefix with VITE_ — that would bundle it
# into the public JS and let anyone burn your gas budget. Set as THIRDWEB_SECRET_KEY
# above (line ~188) instead.
# WalletConnect — project ID (get from cloud.walletconnect.com)
VITE_WALLETCONNECT_PROJECT_ID=

# Firebase web client config (public web SDK credentials, NOT the admin service account)
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Stripe — publishable key (public, safe for browser)
VITE_STRIPE_PUBLISHABLE_KEY=

# Sentry DSN for the web app (public — safe in the client bundle).
# Get from sentry.io/settings/{org}/projects/{project}/keys/.
# VITE_SENTRY_DSN=
# Release identifier surfaced to Sentry — usually the git SHA, injected at
# build time by CI (e.g. `VITE_RELEASE=$(git rev-parse --short HEAD)`).
# VITE_RELEASE=

# Product analytics — PostHog (web). Use the PROJECT API key;
# it's public-safe (write-only, scoped to one project).
# VITE_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# VITE_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# MOBILE — Expo (EXPO_PUBLIC_ prefix = bundled into the app)
# ⚠  Everything with EXPO_PUBLIC_ is visible in the JS bundle — no secrets here.
# apps/mobile reads these at build time via `expo-env`.
# ============================================
# EXPO_PUBLIC_SERVER_URL=https://api.loar.fun
# EXPO_PUBLIC_THIRDWEB_CLIENT_ID=
# EXPO_PUBLIC_APP_ENV=production                # production | staging | development
# EXPO_PUBLIC_SENTRY_DSN=
# EXPO_PUBLIC_RELEASE=                          # git SHA injected by CI at build time
# EXPO_PUBLIC_POSTHOG_KEY=phc_xxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# EXPO_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# ============================================
# INDEXER — Ponder
# ============================================
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# Optional comma-separated fallback RPCs (public fallbacks are always appended)
# PONDER_RPC_FALLBACKS=https://your-backup-rpc.com,https://another-rpc.com
# Which chain to index: "sepolia" (default) or "base-sepolia"
# PONDER_CHAIN=sepolia
# Base Sepolia RPC URL (used when PONDER_CHAIN=base-sepolia)
# RPC_URL_BASE_SEPOLIA=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================================
# CIRCLE — Developer Controlled Wallets (server-side KMS)
# ============================================
# Each user gets a Circle-managed EOA; the server signs via Circle's KMS so
# users only need email/social credentials. Without all three, /auth/circle/*
# and /api/tx/write return 503.
#
# 1. API key: console.circle.com → Developer Controlled Wallets → API Keys.
#    Value includes the "TEST_API_KEY:" / "LIVE_API_KEY:" prefix — paste verbatim.
CIRCLE_API_KEY=
# 2. Entity secret: generate at console → Configurator, register once, store here.
#    (Circle refuses to sign without it.)
CIRCLE_ENTITY_SECRET=
# 3. Wallet set to create new user wallets in (create one via console or SDK).
CIRCLE_WALLET_SET_ID=
# 4. Optional: extra contract addresses the signing oracle should accept,
#    comma-separated as "chainId:0xaddr". Use ONLY for testnet ad-hoc contracts
#    that aren't in packages/abis (Firestore `universes.tokenAddress` is
#    allowlisted automatically).
# CONTRACT_ALLOWLIST_EXTRA=84532:0xabc...,11155111:0xdef...

# ============================================
# OAuth — Google social login idToken verification
# ============================================
# /auth/circle/social verifies the idToken against Google's JWKS before
# trusting the email. Leave empty to hide the Google sign-in button.
# Client ID format: "12345-abc.apps.googleusercontent.com"
GOOGLE_OAUTH_CLIENT_ID=
# Frontend needs the same value with VITE_ prefix to render the button.
VITE_GOOGLE_OAUTH_CLIENT_ID=

# ============================================
# GOVERNANCE — Gnosis Safe + TimelockController
# ============================================
# Deployed via: forge script script/DeployGovernance.s.sol --rpc-url base --broadcast --verify
# SAFE_ADDRESS=0x...                   # 3-of-5 Gnosis Safe multisig
# TIMELOCK_ADDRESS=0x...               # TimelockController (48h delay)

# ============================================
# BACKUP — Firestore disaster recovery
# ============================================
# GCS bucket for Firestore exports (create: gsutil mb gs://your-bucket)
# IAM: service account needs Cloud Datastore Import Export Admin + Storage Admin
FIRESTORE_BACKUP_BUCKET=
# Optional path prefix inside the bucket (default: "backups")
# FIRESTORE_BACKUP_PREFIX=backups

# ============================================
# CONTRACTS — Foundry (see also apps/contracts/.env.example)
# ============================================
# Sepolia testnet
# RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_1=YOUR_ETHERSCAN_API_KEY

# Base Sepolia testnet
# RPC_84532=https://base-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_84532=YOUR_BASESCAN_API_KEY

# Base mainnet
# RPC_8453=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_8453=YOUR_BASESCAN_API_KEY
# RPC_URL_BASE=https://base-mainnet.g.alchemy.com/v2/YOUR_KEY

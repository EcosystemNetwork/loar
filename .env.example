# ============================================
# LOAR — Environment Variables
# ============================================
# Copy to .env and fill in your values:  cp .env.example .env
# All apps (server, web, indexer) read from this single root file.

# ============================================
# REQUIRED — Server won't start without these
# ============================================

# Secret for signing SIWE session JWTs (generate: openssl rand -hex 32)
SIWE_JWT_SECRET=

# Firebase Firestore — provide JSON string OR file path (one is required in production)
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# ============================================
# Server
# ============================================
NODE_ENV=development
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ============================================
# Web (VITE_ prefix = exposed to browser)
# ============================================
VITE_SERVER_URL=http://localhost:3000
VITE_PONDER_URL=http://localhost:42069

# Admin toolbar — comma-separated wallet addresses (empty = all authenticated users)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# $LOAR token contract address (Sepolia)
VITE_LOAR_TOKEN_ADDRESS=
# Treasury wallet address for $LOAR purchases
VITE_TREASURY_ADDRESS=
# Firebase project ID (used by admin toolbar + docs)
VITE_FIREBASE_PROJECT_ID=

# ============================================
# Indexer (Ponder) — REQUIRED for indexer
# ============================================
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================================
# AI Services (optional — server starts without them)
# ============================================
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=
MESHY_API_KEY=
ELEVENLABS_API_KEY=

# ============================================
# Blockchain / Web3
# ============================================
# Wallet private key (for on-chain operations, no 0x prefix)
PRIVATE_KEY=

# Admin wallet address — required for admin routes (0x...)
ADMIN_WALLET=
# Admin tRPC middleware — comma-separated wallets (empty = all authenticated users are admin)
# ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# Credits awarded on universe mint (default: 5000)
# UNIVERSE_MINT_CREDITS=5000

# ============================================
# Storage — Firebase Storage
# ============================================
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ============================================
# Decentralized Storage (optional)
# ============================================
# Pinata — hot path, public delivery, client uploads
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# Lighthouse — permanent Filecoin storage + token-gated encrypted assets
# Get API key at: https://lighthouse.storage
LIGHTHOUSE_API_KEY=

# Storacha — extra decentralized resilience for large media archives
# One-time setup: npx w3 key create → STORACHA_KEY
#   npx w3 login email && npx w3 space create loar
#   npx w3 delegation create <did> --can 'upload/add' --can 'filecoin/offer' | base64 → STORACHA_PROOF
STORACHA_KEY=
STORACHA_PROOF=

# Provider priority (comma-separated, first available wins for primary upload)
STORAGE_PROVIDER_PRIORITY=pinata,lighthouse,storacha,firebase

# ============================================
# Mobile (Expo — EXPO_PUBLIC_ prefix = exposed to app)
# ============================================
EXPO_PUBLIC_SERVER_URL=http://localhost:3000

# ============================================
# Coinbase Developer Platform (optional)
# ============================================
# VITE_CDP_PROJECT_ID=
# VITE_CDP_API_KEY=
# VITE_CDP_API_SECRET=

# ============================================
# Contracts (Foundry) — see also apps/contracts/.env.example
# ============================================
# RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_1=YOUR_ETHERSCAN_API_KEY

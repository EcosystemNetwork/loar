# ============================================
# LOAR — Centralized Environment Variables
# ============================================
# Copy this to .env and fill in your values.
# All apps (server, web, indexer) read from this single file.

# ============================================
# Firebase (Auth + Firestore)
# ============================================
# Server — paste the full JSON or use a file path
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Web (Vite exposes VITE_ prefixed vars to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================
# SIWE Authentication (JWT sessions for wallet-based auth)
# ============================================
# Secret for signing SIWE session JWTs (generate a random 256-bit hex string)
SIWE_JWT_SECRET=

# ============================================
# Server
# ============================================
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ============================================
# Web
# ============================================
VITE_SERVER_URL=http://localhost:3000
VITE_PONDER_URL=http://localhost:42069

# Admin toolbar — comma-separated wallet addresses (empty = all authenticated users)
# VITE_ADMIN_ADDRESSES=0x1234...5678,0xabcd...ef01

# ============================================
# AI Services
# ============================================
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ============================================
# Blockchain / Web3
# ============================================
# Wallet private key (for Synapse/Filecoin uploads)
PRIVATE_KEY=

# ============================================
# Indexer (Ponder)
# ============================================
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================================
# Storage (Firebase Storage)
# ============================================
# Same as VITE_FIREBASE_STORAGE_BUCKET — used by server for file uploads
FIREBASE_STORAGE_BUCKET=your-project.firebasestorage.app

# ============================================
# Decentralized Storage
# ============================================
# Walrus (testnet defaults — leave blank to use public testnet)
WALRUS_PUBLISHER_URL=https://publisher.walrus-testnet.walrus.space
WALRUS_AGGREGATOR_URL=https://aggregator.walrus-testnet.walrus.space

# IPFS via Pinata (get JWT at https://app.pinata.cloud)
PINATA_JWT=
PINATA_GATEWAY_URL=https://gateway.pinata.cloud

# Provider priority order (comma-separated, first = highest priority)
STORAGE_PROVIDER_PRIORITY=walrus,ipfs,synapse,firebase

# ============================================
# Coinbase Developer Platform (optional)
# ============================================
# VITE_CDP_PROJECT_ID=
# VITE_CDP_API_KEY=
# VITE_CDP_API_SECRET=

# ============================================
# Contracts (Foundry — used by forge only)
# ============================================
# RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_1=YOUR_ETHERSCAN_API_KEY

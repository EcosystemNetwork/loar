# ============================================
# LOAR — Centralized Environment Variables
# ============================================
# Copy this to .env and fill in your values.
# All apps (server, web, indexer) read from this single file.

# ============================================
# Firebase (Auth + Firestore)
# ============================================
# Server — paste the full JSON or use a file path
FIREBASE_SERVICE_ACCOUNT='{"type":"service_account","project_id":"...","private_key":"...","client_email":"..."}'
# FIREBASE_SERVICE_ACCOUNT_PATH=./firebase-service-account.json

# Web (Vite exposes VITE_ prefixed vars to the browser)
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================
# Server
# ============================================
PORT=3000
CORS_ORIGIN=http://localhost:3001

# ============================================
# Web
# ============================================
VITE_SERVER_URL=http://localhost:3000
VITE_PONDER_URL=http://localhost:42069

# ============================================
# AI Services
# ============================================
FAL_KEY=
GOOGLE_API_KEY=
OPENAI_API_KEY=

# ============================================
# Blockchain / Web3
# ============================================
# Wallet private key (for Synapse/Filecoin uploads)
PRIVATE_KEY=

# ============================================
# Indexer (Ponder)
# ============================================
PONDER_RPC_URL_2=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY

# ============================================
# Storage (MinIO / S3)
# ============================================
MINIO_ENDPOINT=http://localhost:9000
MINIO_REGION=us-east-1
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_NAME=loar-videos

# ============================================
# Coinbase Developer Platform (optional)
# ============================================
# VITE_CDP_PROJECT_ID=
# VITE_CDP_API_KEY=
# VITE_CDP_API_SECRET=

# ============================================
# Contracts (Foundry — used by forge only)
# ============================================
# RPC_11155111=https://eth-sepolia.g.alchemy.com/v2/YOUR_KEY
# VERIFICATION_KEY_1=YOUR_ETHERSCAN_API_KEY
